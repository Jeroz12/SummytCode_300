{
  "name": "plc-ide",
  "version": "0.1.0",
  "description": "IDE de programación PLC para MCU",
  "private": true,
  "main": "dist/src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "tsc -p src/tsconfig.main.json && electron .",
    "dev:renderer": "vite --config src/vite.config.ts",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build --config src/vite.config.ts",
    "build:main": "tsc -p src/tsconfig.main.json"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "electron": "^28.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}

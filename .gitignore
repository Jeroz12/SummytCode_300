# --- Rust / Tauri ---
target/
src-tauri/target/
Cargo.lock
**/*.rs.bk
*.pdb

# --- Tauri build output ---
src-tauri/gen/
src-tauri/WixTools/

# --- Env / secrets ---
.env
.env.*
!.env.example

# --- Toolchains empaquetados (no versionar binarios pesados) ---
/toolchains/
*.exe
*.dll
*.so
*.dylib

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- Proyectos de usuario generados por la app (no son parte del repo) ---
*.plcproj.bak

# --- Código C generado por el compilador PLC (artefacto de build, no fuente) ---
/generated/

# --- Testing / coverage ---
coverage/
.nyc_output/
